<Window x:Class="FileRouter.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:views="clr-namespace:FileRouter.Wpf.Views"
        Title="FileRouter" Width="1280" Height="860" Icon="/app.ico"
        Style="{StaticResource {x:Type Window}}">
    <Window.InputBindings>
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{Binding SkipCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Escape" Command="{Binding StopCommand}" />
    </Window.InputBindings>
    <DockPanel>
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Theme.WindowBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- rescan lives in the header, top-right — always in the same
                 spot, hidden while filing (Stop/Esc is the deliberate way
                 out of a session; a stray refresh must not end it) -->
            <Button Grid.Column="1" Command="{Binding RescanCommand}"
                    Content="Refresh" Height="26" Padding="10,0" Margin="0,2,6,2"
                    ToolTip="Rescan the inbox now">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource Theme.SurfaceHover}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Menu Padding="4,2">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings…" Click="OnSettings" InputGestureText="Ctrl+," />
                <Separator />
                <MenuItem Header="_View history…" Click="OnViewHistory" />
                <MenuItem Header="_Export history to spreadsheet…"
                          Command="{Binding ExportHistoryCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Unlock PDFs…" Click="OnUnlock" />
                <MenuItem Header="_Bulk rename…" Click="OnBulkRename" />
                <MenuItem Header="_Match and merge…" Click="OnMatchMerge" />
            </MenuItem>
            </Menu>
        </Grid>

        <!-- set-aside banner: a full-width filled warning bar on every screen
             while deferred files exist — the old thin status-bar text was too
             easy to miss. Clicking opens the folder. -->
        <Button DockPanel.Dock="Bottom"
                Command="{Binding OpenDeferredCommand}"
                Visibility="{Binding HasDeferred, Converter={StaticResource BoolToVis}}"
                Cursor="Hand" FontWeight="SemiBold" FontSize="15"
                AutomationProperties.Name="{Binding DeferredAlert}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bar" Background="{DynamicResource Theme.Warning}"
                            Padding="14,11" SnapsToDevicePixels="True">
                        <TextBlock Text="{Binding DeferredAlert}"
                                   Foreground="{DynamicResource Theme.WarningText}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bar" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bar" Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ViewerCol" Width="*" MinWidth="320" />
                <ColumnDefinition x:Name="SplitterCol" Width="5" />
                <ColumnDefinition x:Name="PanelCol" Width="430" MinWidth="370" />
            </Grid.ColumnDefinitions>
            <wv2:WebView2 x:Name="Viewer" Grid.Column="0" />
            <GridSplitter x:Name="Split" Grid.Column="1" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext" />
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource Theme.WindowBg}">
                <Grid Margin="16,12">
                    <views:ReadyView Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}" />
                    <views:ProcessingView Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                    <views:DoneView Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
