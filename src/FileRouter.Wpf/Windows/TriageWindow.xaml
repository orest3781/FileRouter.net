<Window x:Class="FileRouter.Wpf.Windows.TriageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="FileRouter — Triage" Width="1150" Height="720" MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Style="{StaticResource {x:Type Window}}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="440" MinWidth="380" />
        </Grid.ColumnDefinitions>
        <wv2:WebView2 x:Name="Viewer" />
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" />
        <DockPanel Grid.Column="2" Margin="12">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock x:Name="Progress" Style="{StaticResource HeadlineText}" FontSize="20" />
                <TextBlock x:Name="FileName" Style="{StaticResource SubtleText}"
                           TextWrapping="Wrap" Margin="0,4,0,10" />
                <TextBlock Text="Which row does this document belong to?" Margin="0,0,0,6" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Bottom">
                <TextBlock x:Name="Note" Style="{StaticResource StatusText}" Margin="0,8,0,8" />
                <Button x:Name="UseButton" Content="Use selected id" Click="OnUseSelected"
                        Style="{StaticResource PrimaryButton}" Height="40" IsEnabled="False" />
                <Button Content="Skip this file" Click="OnSkip" Height="34" Margin="0,6,0,0" />
                <Button Content="Stop triage" Click="OnStop" Height="34" Margin="0,6,0,0" />
            </StackPanel>
            <DataGrid x:Name="Candidates" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single"
                      SelectionChanged="OnCandidateSelected" />
        </DockPanel>
    </Grid>
</Window>
