<Window x:Class="FileRouter.Wpf.Windows.UnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileRouter.Wpf.ViewModels"
        Title="FileRouter — Unlock PDFs" Width="620" Height="660" MinWidth="540" MinHeight="560"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" AllowDrop="True"
        DragOver="OnDragOver" Drop="OnDrop"
        Style="{StaticResource {x:Type Window}}">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Unlock" Command="{Binding UnlockCommand}"
                    Style="{StaticResource PrimaryButton}" Width="110" Margin="0,0,8,0" />
            <Button Content="Close" Width="96" IsCancel="True" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="PDFs to unlock:" Margin="0,0,0,6" FontWeight="SemiBold" />
            <Grid Grid.Row="1">
                <ListBox x:Name="FileList" ItemsSource="{Binding Files}"
                         SelectionMode="Extended" MinHeight="120"
                         AutomationProperties.Name="PDFs to unlock">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- the filename is the news; the path is hover detail -->
                            <TextBlock Text="{Binding Converter={StaticResource FileName}}"
                                       ToolTip="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="Drag PDFs anywhere on this window, or press Add files…"
                           Style="{StaticResource SubtleText}" Margin="10" IsHitTestVisible="False">
                    <TextBlock.Visibility>
                        <Binding Path="Files.Count" Converter="{StaticResource ZeroToVis}" />
                    </TextBlock.Visibility>
                </TextBlock>
            </Grid>

            <DockPanel Grid.Row="2" Margin="0,8,0,8">
                <Button Content="Add files…" Click="OnAddFiles" Margin="0,0,6,0" />
                <Button Content="Remove selected" Click="OnRemoveSelected" Margin="0,0,6,0" />
                <Button Content="Clear" Command="{Binding ClearCommand}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding AddNote}" Style="{StaticResource SubtleText}"
                           FontSize="11" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Password:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <PasswordBox Grid.Column="1" x:Name="PwBox" PasswordChanged="OnPasswordChanged"
                             AutomationProperties.Name="Password" />
                <TextBox Grid.Column="1" x:Name="PwPlain" Visibility="Collapsed"
                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Password (visible)" />
                <CheckBox Grid.Column="2" x:Name="ShowPw" Content="Show" Margin="8,0,0,0"
                          VerticalAlignment="Center" Checked="OnShowPw" Unchecked="OnShowPw" />
                <TextBlock Grid.Column="3" Text="Saved:" VerticalAlignment="Center"
                           Margin="16,0,6,0" Style="{StaticResource SubtleText}" />
                <ComboBox Grid.Column="4" MinWidth="130"
                          ItemsSource="{Binding Saved}" DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedSaved}"
                          AutomationProperties.Name="Saved passwords" />
            </Grid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox Content="Keep a copy instead of replacing the original"
                          IsChecked="{Binding KeepCopy}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CopySuffixHint}" Style="{StaticResource SubtleText}"
                           FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding KeepCopy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Remember this password as:" VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBox Width="160" Text="{Binding RememberLabel, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Remember password as" />
                <TextBlock Text="saved only when it unlocks something"
                           Style="{StaticResource SubtleText}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="6" Text="{Binding Summary}" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <Border Grid.Row="7" Background="{DynamicResource Theme.Surface}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,6">
                    <ItemsControl ItemsSource="{Binding ResultLines}"
                                  AutomationProperties.Name="Results">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}"
                                                             Value="{x:Static vm:UnlockResultKind.Fail}">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource Theme.StatusAmber}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}"
                                                             Value="{x:Static vm:UnlockResultKind.Skip}">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource Theme.SubtleText}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
