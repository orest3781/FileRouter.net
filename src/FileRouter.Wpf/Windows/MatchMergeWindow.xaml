<Window x:Class="FileRouter.Wpf.Windows.MatchMergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileRouter — Match and merge" Width="840" Height="640" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" AllowDrop="True"
        DragOver="OnDragOver" Drop="OnDrop"
        Style="{StaticResource {x:Type Window}}">
    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="Close" Width="96" IsCancel="True" />
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding MergeButtonText}" Command="{Binding MergeCommand}"
                        Style="{StaticResource PrimaryButton}" MinWidth="120" Margin="0,0,8,0" />
                <Button Content="{Binding TriageButtonText}" Click="OnTriage"
                        IsEnabled="{Binding CanTriage}" Margin="0,0,8,0" />
                <Button Content="Undo last merge" Command="{Binding UndoCommand}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           Style="{StaticResource StatusText}" MaxWidth="300" />
            </StackPanel>
        </DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Roster:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Grid Grid.Column="1">
                    <TextBox Text="{Binding RosterPath, Mode=OneWay}" IsReadOnly="True" />
                    <TextBlock Text="no roster loaded yet — pick the CSV with names and Control IDs"
                               FontSize="11"
                               VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RosterPath}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Grid.Column="2" Content="Load spreadsheet (CSV)…" Margin="6,0,0,0"
                        Command="{Binding LoadRosterCommand}" />
            </Grid>

            <!-- header mapping means nothing until a roster is in -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding HasRoster, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="First name:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox MinWidth="140" ItemsSource="{Binding Headers}"
                          SelectedItem="{Binding FirstHeader}" Margin="0,0,12,0" />
                <TextBlock Text="Last name:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox MinWidth="140" ItemsSource="{Binding Headers}"
                          SelectedItem="{Binding LastHeader}" Margin="0,0,12,0" />
                <TextBlock Text="Control ID:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox MinWidth="140" ItemsSource="{Binding Headers}"
                          SelectedItem="{Binding ControlHeader}" />
            </StackPanel>

            <DockPanel Grid.Row="2" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Add PDFs…" Click="OnAddFiles" Margin="0,0,6,0" />
                    <Button Content="Add a folder's PDFs…" Click="OnAddFolder" Margin="0,0,6,0" />
                    <Button Content="Remove selected" Click="OnRemoveSelected" Margin="0,0,6,0" />
                    <Button Content="Clear" Command="{Binding ClearCommand}" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding AddNote}" Style="{StaticResource SubtleText}"
                               FontSize="11" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="3">
                <DataGrid x:Name="MatchGrid" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                          SelectionMode="Extended">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="ToolTip" Value="{Binding Source}" />
                            <Style.Triggers>
                                <!-- ready rows read normal; ambiguous amber;
                                     the rest recede -->
                                <DataTrigger Binding="{Binding Status}" Value="ambiguous">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Theme.StatusAmber}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="already">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Theme.SubtleText}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="no_match">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Theme.SubtleText}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="no_name">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Theme.SubtleText}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File" Binding="{Binding File}" Width="*" />
                        <DataGridTextColumn Header="Becomes" Binding="{Binding Becomes}" Width="*" />
                        <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="240" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Style="{StaticResource SubtleText}" Margin="10,36,10,10"
                           IsHitTestVisible="False" TextWrapping="Wrap"
                           Text="1)  Load the roster CSV above    2)  Add or drag PDFs anywhere on this window    3)  Merge the matches; Triage the ambiguous ones">
                    <TextBlock.Visibility>
                        <Binding Path="Rows.Count" Converter="{StaticResource ZeroToVis}" />
                    </TextBlock.Visibility>
                </TextBlock>
            </Grid>

            <TextBlock Grid.Row="4" Text="{Binding BucketsLine}" FontWeight="SemiBold"
                       Margin="0,6,0,0" />
        </Grid>
    </DockPanel>
</Window>
