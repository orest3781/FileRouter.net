<UserControl x:Class="FileRouter.Wpf.Views.ProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="{Binding ProgressLine}" Style="{StaticResource HeadlineText}" />
        <TextBlock Text="{Binding CurrentFilename}" Style="{StaticResource SubtleText}"
                   TextWrapping="Wrap" Margin="0,4,0,0" />

        <TextBlock Text="Name:" Margin="0,14,0,4" FontWeight="SemiBold" />
        <TextBox x:Name="NameBox" FontSize="16"
                 Text="{Binding TypedName, UpdateSourceTrigger=PropertyChanged}"
                 PreviewKeyDown="NameBox_PreviewKeyDown"
                 LostKeyboardFocus="NameBox_LostKeyboardFocus"
                 TextChanged="NameBox_TextChanged"
                 AutomationProperties.Name="Name">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding UppercaseNames}" Value="True">
                            <Setter Property="CharacterCasing" Value="Upper" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
        <Popup x:Name="SuggestPopup" PlacementTarget="{Binding ElementName=NameBox}"
               Placement="Bottom" StaysOpen="True" AllowsTransparency="True"
               IsOpen="{Binding HasSuggestions, Mode=OneWay}"
               Width="{Binding ActualWidth, ElementName=NameBox}">
            <ListBox x:Name="SuggestList" ItemsSource="{Binding Suggestions}"
                     Focusable="False" MaxHeight="220"
                     SelectionChanged="SuggestList_SelectionChanged" />
        </Popup>
        <TextBlock Style="{StaticResource SubtleText}" FontSize="11" Margin="0,3,0,0"
                   Text="Tab completes a word · blank files without renaming" />

        <TextBlock Text="Will be filed as:" Margin="0,12,0,2" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Preview}" TextWrapping="Wrap" MinHeight="40">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PreviewIsWarning}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Danger}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ItemsControl ItemsSource="{Binding Routes}" Margin="0,10,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Height="44" Margin="0,3"
                            Command="{Binding DataContext.RouteCommand,
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Index}"
                            IsEnabled="{Binding Enabled}"
                            ToolTip="{Binding DisabledReason}"
                            ToolTipService.ShowOnDisabled="True"
                            Background="{Binding Back, Converter={StaticResource RgbToBrush}}"
                            Foreground="{Binding Fore, Converter={StaticResource RgbToBrush}}"
                            AutomationProperties.Name="{Binding Label}">
                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding Fore, Converter={StaticResource RgbToBrush}}" />
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="Set aside   ·   Ctrl+K" Command="{Binding SkipCommand}"
                Height="36" Margin="0,10,0,0" />
        <Button Content="Undo last   ·   Ctrl+Shift+Z" Command="{Binding UndoCommand}"
                Height="36" Margin="0,6,0,0" />
        <Button Content="Stop   ·   Esc" Command="{Binding StopCommand}"
                Height="36" Margin="0,6,0,0" />

        <TextBlock Text="{Binding StatusLine}" Style="{StaticResource StatusText}"
                   Margin="0,12,0,0" />
    </StackPanel>
</UserControl>
