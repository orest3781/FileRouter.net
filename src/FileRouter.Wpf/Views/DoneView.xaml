<UserControl x:Class="FileRouter.Wpf.Views.DoneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="{Binding CountLine}" Style="{StaticResource HeadlineText}" />
        <TextBlock Text="{Binding DetailLine}" TextWrapping="Wrap" Margin="0,6,0,0" />
        <Button Content="Rescan inbox" Command="{Binding RescanCommand}"
                Height="36" Margin="0,18,0,0" />
    </StackPanel>
</UserControl>
