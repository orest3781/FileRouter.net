<Window x:Class="FileRouter.Wpf.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileRouter.Wpf.ViewModels"
        Title="FileRouter — Settings" Width="880" Height="760" MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Style="{StaticResource {x:Type Window}}">
    <Window.Resources>
        <DataTemplate x:Key="KvpValueTemplate">
            <TextBlock Text="{Binding Value}" />
        </DataTemplate>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="FieldRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <!-- per-field live note: amber, collapsed while empty -->
        <Style x:Key="NoteText" TargetType="TextBlock" BasedOn="{StaticResource StatusText}">
            <Setter Property="Margin" Value="130,-6,0,10" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionTab" TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="MinWidth" Value="120" />
        </Style>
        <!-- 22px + 3px gap keeps all 12 swatches on ONE row in the detail
             columns (12 × 25 = 300px); at 24 + 4 they wrapped and the second
             row clipped against the editor's bottom edge -->
        <Style x:Key="Swatch" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="0,0,3,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK" Click="OnOk" Style="{StaticResource PrimaryButton}"
                    Width="96" IsDefault="True" Margin="0,0,8,0" />
            <Button Content="Cancel" Width="96" IsCancel="True" />
        </StackPanel>

        <TabControl TabStripPlacement="Left" Background="Transparent" BorderThickness="0"
                    ItemContainerStyle="{StaticResource SectionTab}">

            <!-- ============================================== General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8">
                        <TextBlock Text="Folders" FontWeight="Bold" Margin="0,0,0,10" />

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Inbox:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding Inbox, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                    Command="{Binding BrowseInboxCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding InboxNote}" Style="{StaticResource NoteText}" />

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Set-aside folder:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding Deferred, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                    Command="{Binding BrowseDeferredCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding DeferredNote}" Style="{StaticResource NoteText}" />

                        <TextBlock Text="Files" FontWeight="Bold" Margin="0,10,0,10" />

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Names list:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding NamesFile, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                    Command="{Binding BrowseNamesFileCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding NamesFileNote}" Style="{StaticResource NoteText}" />

                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="History database:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding HistoryDb, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                    Command="{Binding BrowseHistoryDbCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding HistoryDbNote}" Style="{StaticResource NoteText}" />
                        <DockPanel Margin="0,2,0,0">
                            <Button DockPanel.Dock="Right" Content="Open backups folder"
                                    Command="{Binding OpenBackupsCommand}" Margin="8,0,0,0"
                                    VerticalAlignment="Top" />
                            <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                                       Text="A daily backup of the history database is kept in a 'backups' folder beside it." />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================== Filing -->
            <TabItem Header="Filing">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8">
                        <TextBlock Text="Naming" FontWeight="Bold" Margin="0,0,0,10" />
                        <RadioButton Content="Insert at the -- — the typed name replaces the first -- in the filename"
                                     IsChecked="{Binding InsertMode}" />
                        <RadioButton Content="Full replace — the typed name becomes the whole filename"
                                     IsChecked="{Binding InsertMode, Converter={StaticResource InvertBool}}" />
                        <!-- one live example tying mode + UPPERCASE + separator together -->
                        <Border Background="{DynamicResource Theme.Surface}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                CornerRadius="4" Padding="10,7" Margin="0,8,0,0">
                            <TextBlock Text="{Binding FilingExample}" TextWrapping="Wrap"
                                       FontWeight="SemiBold" />
                        </Border>

                        <Grid Style="{StaticResource FieldRow}" Margin="0,14,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Process order:" Style="{StaticResource FieldLabel}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Static vm:SettingsViewModel.SortChoices}"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SortKey}"
                                      ItemTemplate="{StaticResource KvpValueTemplate}" />
                        </Grid>

                        <TextBlock Text="Typing" FontWeight="Bold" Margin="0,10,0,10" />
                        <CheckBox Content="UPPERCASE names as they're typed"
                                  IsChecked="{Binding UppercaseNames}" />
                        <CheckBox Content="Enter files to the last-used destination"
                                  IsChecked="{Binding EnterCommits}" />
                        <Grid Style="{StaticResource FieldRow}" Margin="0,8,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Word separator:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding WordSeparator, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="3" />
                            <TextBlock Grid.Column="2" Style="{StaticResource SubtleText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Text="typed spaces become this (blank = keep spaces)" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================== Routes -->
            <TabItem Header="Destinations">
                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel>
                        <WrapPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                            <Button Content="Add" Command="{Binding AddRouteCommand}" MinWidth="48" Margin="0,0,4,4" />
                            <Button Content="Duplicate" Command="{Binding DuplicateRouteCommand}" Margin="0,0,4,4"
                                    ToolTip="A copy of the selected destination to tweak (hotkey left blank)" />
                            <Button Content="Remove" Command="{Binding RemoveRouteCommand}" Margin="0,0,4,4" />
                            <Button Content="↑" Command="{Binding RouteUpCommand}" MinWidth="34" Margin="0,0,4,4"
                                    ToolTip="Move up — buttons show in this order (or drag rows)" />
                            <Button Content="↓" Command="{Binding RouteDownCommand}" MinWidth="34" Margin="0,0,0,4"
                                    ToolTip="Move down — buttons show in this order (or drag rows)" />
                        </WrapPanel>
                        <Grid>
                            <ListBox x:Name="RouteList" ItemsSource="{Binding Routes}"
                                     SelectedItem="{Binding SelectedRoute}" AllowDrop="True"
                                     PreviewMouseLeftButtonDown="List_DragArm"
                                     PreviewMouseMove="List_DragMove"
                                     Drop="List_Drop" DragOver="List_DragOver">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2"
                                                       VerticalAlignment="Center" Margin="0,0,7,0"
                                                       Fill="{Binding Color, Converter={StaticResource ColorStringToBrush}}"
                                                       Stroke="{DynamicResource Theme.Border}" StrokeThickness="1" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding GestureText}"
                                                       Style="{StaticResource SubtleText}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="No destination buttons yet — press Add."
                                       Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                                       Margin="10" IsHitTestVisible="False">
                                <TextBlock.Visibility>
                                    <Binding Path="Routes.Count" Converter="{StaticResource ZeroToVis}" />
                                </TextBlock.Visibility>
                            </TextBlock>
                        </Grid>
                    </DockPanel>

                    <ScrollViewer Grid.Column="1" Margin="16,0,0,0" VerticalScrollBarVisibility="Auto"
                                  DataContext="{Binding SelectedRoute}">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Button label:" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Folder:" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                        Command="{Binding DataContext.BrowseRoutePathCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Button Grid.Column="3" Content="Open" Margin="6,0,0,0"
                                        ToolTip="Show this folder in Explorer"
                                        Command="{Binding DataContext.OpenRouteFolderCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="110,0,0,10">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Problem}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                <TextBlock Text="{Binding Problem}" Style="{StaticResource StatusText}"
                                           VerticalAlignment="Center" />
                                <Button Content="Create it" Margin="8,0,0,0" Padding="8,3"
                                        Command="{Binding DataContext.CreateRouteFolderCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Problem}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hotkey:" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1" Text="{Binding Hotkey, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                         AutomationProperties.Name="Hotkey — press keys to set" />
                                <TextBlock Grid.Column="2" Style="{StaticResource SubtleText}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           TextWrapping="Wrap"
                                           Text="press the keys · Backspace clears" />
                            </Grid>
                            <TextBlock Text="{Binding HotkeyNote}" Style="{StaticResource StatusText}"
                                       Margin="110,0,0,10"
                                       Visibility="{Binding HasHotkeyNote, Converter={StaticResource BoolToVis}}" />

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Filename suffix:" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1" Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding AppendSuffix}" />
                                <CheckBox Grid.Column="2" Content="append it" Margin="8,0,0,0"
                                          VerticalAlignment="Center" IsChecked="{Binding AppendSuffix}" />
                            </Grid>

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Naming mode:" Style="{StaticResource FieldLabel}" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{x:Static vm:SettingsViewModel.ModeChoices}"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding NamingMode}"
                                          ItemTemplate="{StaticResource KvpValueTemplate}" />
                            </Grid>

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Button color:" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1" Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <ItemsControl ItemsSource="{x:Static vm:SettingsViewModel.SwatchColors}"
                                          Margin="110,2,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource Swatch}" Click="OnRouteSwatch"
                                                Tag="{Binding}" ToolTip="{Binding}"
                                                AutomationProperties.Name="{Binding}"
                                                Foreground="{Binding Converter={StaticResource ColorStringToForeBrush}}">
                                            <Button.Background>
                                                <SolidColorBrush Color="{Binding}" />
                                            </Button.Background>
                                            <!-- ✓ marks the swatch matching the current color -->
                                            <TextBlock FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource SwatchCheck}">
                                                        <Binding />
                                                        <Binding Path="DataContext.SelectedRoute.Color"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- the button exactly as the Processing screen
                                 will render it: color, contrast-picked text,
                                 label · suffix · hotkey -->
                            <TextBlock Text="Preview:" Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,4" />
                            <Border Height="44" CornerRadius="4"
                                    Background="{Binding PreviewBack, Converter={StaticResource RgbToBrush}}">
                                <TextBlock Text="{Binding PreviewLabel}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding PreviewFore, Converter={StaticResource RgbToBrush}}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ============================================== Dashboard -->
            <TabItem Header="Dashboard">
                <Grid Margin="16,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Section heading:" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1" Text="{Binding MonitorTitle, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <TextBlock Grid.Row="1" Text="Monitored folders" FontWeight="Bold" Margin="0,14,0,8" />
                    <!-- the folder editor takes all remaining height — a long
                         folder list gets the space, not a cramped fixed strip -->
                    <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                    <Button Content="Add" Command="{Binding AddWatchCommand}" MinWidth="48" Margin="0,0,4,4" />
                                    <Button Content="Remove" Command="{Binding RemoveWatchCommand}" Margin="0,0,4,4" />
                                    <Button Content="↑" Command="{Binding WatchUpCommand}" MinWidth="34" Margin="0,0,4,4"
                                            ToolTip="Move up — tiles show in this order (or drag rows)" />
                                    <Button Content="↓" Command="{Binding WatchDownCommand}" MinWidth="34" Margin="0,0,0,4"
                                            ToolTip="Move down — tiles show in this order (or drag rows)" />
                                </WrapPanel>
                                <ListBox x:Name="WatchList" ItemsSource="{Binding WatchFolders}"
                                         SelectedItem="{Binding SelectedWatch}" AllowDrop="True"
                                         PreviewMouseLeftButtonDown="List_DragArm"
                                         PreviewMouseMove="List_DragMove"
                                         Drop="List_Drop" DragOver="List_DragOver">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2"
                                                           VerticalAlignment="Center" Margin="0,0,7,0"
                                                           Fill="{Binding Color, Converter={StaticResource ColorStringToBrush}}"
                                                           Stroke="{DynamicResource Theme.Border}" StrokeThickness="1" />
                                                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                            <ScrollViewer Grid.Column="1" Margin="16,0,0,0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>
                              <StackPanel DataContext="{Binding SelectedWatch}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid Style="{StaticResource FieldRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Label:" Style="{StaticResource FieldLabel}" />
                                    <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Style="{StaticResource FieldRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Folder:" Style="{StaticResource FieldLabel}" />
                                    <TextBox Grid.Column="1" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                            Command="{Binding DataContext.BrowseWatchPathCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Button Grid.Column="3" Content="Open" Margin="6,0,0,0"
                                            ToolTip="Show this folder in Explorer"
                                            Command="{Binding DataContext.OpenWatchFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="90,0,0,10">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Problem}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{Binding Problem}" Style="{StaticResource StatusText}"
                                               VerticalAlignment="Center" />
                                    <Button Content="Create it" Margin="8,0,0,0" Padding="8,3"
                                            Command="{Binding DataContext.CreateWatchFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Problem}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                                <Grid Style="{StaticResource FieldRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="File types:" Style="{StaticResource FieldLabel}"
                                               VerticalAlignment="Top" Margin="0,4,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <WrapPanel>
                                            <CheckBox Content="Any file" IsChecked="{Binding AnyType}"
                                                      Margin="0,2,14,2" />
                                            <CheckBox Content="PDF" IsChecked="{Binding TypePdf}" Margin="0,2,14,2"
                                                      IsEnabled="{Binding AnyType, Converter={StaticResource InvertBool}}" />
                                            <CheckBox Content="TIFF" IsChecked="{Binding TypeTiff}" Margin="0,2,14,2"
                                                      IsEnabled="{Binding AnyType, Converter={StaticResource InvertBool}}" />
                                            <CheckBox Content="JPEG" IsChecked="{Binding TypeJpeg}" Margin="0,2,14,2"
                                                      IsEnabled="{Binding AnyType, Converter={StaticResource InvertBool}}" />
                                            <CheckBox Content="PNG" IsChecked="{Binding TypePng}" Margin="0,2,14,2"
                                                      IsEnabled="{Binding AnyType, Converter={StaticResource InvertBool}}" />
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                    IsEnabled="{Binding AnyType, Converter={StaticResource InvertBool}}">
                                            <TextBlock Text="other:" Style="{StaticResource SubtleText}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBox Width="120" Text="{Binding OtherTypes}"
                                                     AutomationProperties.Name="Other file types" />
                                            <TextBlock Text="e.g. docx"
                                                       Style="{StaticResource SubtleText}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <CheckBox Content="include subfolders" Margin="90,0,0,10"
                                          IsChecked="{Binding Recursive}"
                                          ToolTip="Alerting files found in a subfolder show 'in ⟨subfolder⟩' on the tile" />
                                <Grid Style="{StaticResource FieldRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Tile color:" Style="{StaticResource FieldLabel}" />
                                    <TextBox Grid.Column="1" Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Static vm:SettingsViewModel.SwatchColors}"
                                              Margin="90,2,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource Swatch}" Click="OnWatchSwatch"
                                                    Tag="{Binding}" ToolTip="{Binding}"
                                                    AutomationProperties.Name="{Binding}"
                                                    Foreground="{Binding Converter={StaticResource ColorStringToForeBrush}}">
                                                <Button.Background>
                                                    <SolidColorBrush Color="{Binding}" />
                                                </Button.Background>
                                                <TextBlock FontWeight="Bold">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SwatchCheck}">
                                                            <Binding />
                                                            <Binding Path="DataContext.SelectedWatch.Color"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>

                              <!-- the card exactly as Ready will show it —
                                   computed against the REAL folder, so count
                                   and alert state are live while you type -->
                              <StackPanel Grid.Row="1" Margin="0,4,0,0"
                                          Visibility="{Binding TilePreviewVisible,
                                                       Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Preview:" Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,4" />
                                <Border Width="230" MinHeight="78" CornerRadius="4" Padding="12,8"
                                        HorizontalAlignment="Left"
                                        Background="{Binding TilePreviewBack, Converter={StaticResource RgbToBrush}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TilePreviewLabel}" FontSize="12"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding TilePreviewFore, Converter={StaticResource RgbToBrush}}" />
                                        <TextBlock Text="{Binding TilePreviewCount}" FontSize="27"
                                                   FontWeight="Bold" Margin="0,2,0,0"
                                                   Foreground="{Binding TilePreviewFore, Converter={StaticResource RgbToBrush}}" />
                                        <TextBlock Text="{Binding TilePreviewNote}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasTilePreviewNote,
                                                                Converter={StaticResource BoolToVis}}"
                                                   Foreground="{Binding TilePreviewFore, Converter={StaticResource RgbToBrush}}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding TilePreviewHint}"
                                           Style="{StaticResource SubtleText}" FontSize="11"
                                           TextWrapping="Wrap" MaxWidth="380"
                                           HorizontalAlignment="Left" Margin="0,4,0,0" />
                              </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Grid>

                    <StackPanel Grid.Row="3">
                        <TextBlock Text="Alerts" FontWeight="Bold" Margin="0,14,0,8" />
                        <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                                   Text="Filenames containing any of these terms flash the tile and the inbox count red (one per line). Matching ignores case and looks at filenames only:" />
                        <TextBox Text="{Binding AlertTextsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="56" Margin="0,6,0,6"
                                 VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="Alert terms" />
                        <CheckBox Content="Flash alerts (uncheck for a steady highlight)"
                                  IsChecked="{Binding FlashAlerts}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============================================== Appearance -->
            <TabItem Header="Appearance">
                <StackPanel Margin="16,8">
                    <TextBlock Text="Colors" FontWeight="Bold" Margin="0,0,0,10" />
                    <RadioButton Content="Follow Windows light/dark mode"
                                 IsChecked="{Binding ThemeAuto}" GroupName="ThemeMode" />
                    <RadioButton Content="Always light" IsChecked="{Binding ThemeLight}"
                                 GroupName="ThemeMode" />
                    <RadioButton Content="Always dark" IsChecked="{Binding ThemeDark}"
                                 GroupName="ThemeMode" />

                    <TextBlock Text="Text" FontWeight="Bold" Margin="0,14,0,10" />
                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="App font:" Style="{StaticResource FieldLabel}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{x:Static vm:SettingsViewModel.FontChoices}"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding UiFontFamily}"
                                  ItemTemplate="{StaticResource KvpValueTemplate}" />
                    </Grid>
                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Base text size:" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1" Text="{Binding UiFontSizeText, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <Button Content="▲" FontSize="8" Padding="6,1" Click="OnSizeUp"
                                    AutomationProperties.Name="Larger text" />
                            <Button Content="▼" FontSize="8" Padding="6,1" Margin="0,2,0,0"
                                    Click="OnSizeDown" AutomationProperties.Name="Smaller text" />
                        </StackPanel>
                        <TextBlock Grid.Column="3" Style="{StaticResource SubtleText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Text="6–72, or blank for the default" />
                    </Grid>

                    <!-- what the choices actually look like, live -->
                    <TextBlock Text="Sample" FontWeight="Bold" Margin="0,14,0,6" />
                    <Border Background="{DynamicResource Theme.Surface}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Will be filed as:  20240115-SMITH JOHN-12345.pdf"
                                       FontFamily="{Binding UiFontFamily, Converter={StaticResource FontFamilyString}}"
                                       FontSize="{Binding UiFontSizeText, Converter={StaticResource FontSizeText}}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="The quick brown fax jumps over 0123456789."
                                       FontFamily="{Binding UiFontFamily, Converter={StaticResource FontFamilyString}}"
                                       FontSize="{Binding UiFontSizeText, Converter={StaticResource FontSizeText}}"
                                       Style="{StaticResource SubtleText}" Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ============================================== Tools & data -->
            <TabItem Header="Tools &amp; data">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8">
                        <TextBlock Text="Unlock PDFs" FontWeight="Bold" Margin="0,0,0,10" />
                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Unlocked copy suffix:" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Text="{Binding UnlockSuffix, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2" Style="{StaticResource SubtleText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"
                                       Text="blank = replace the original after verifying" />
                        </Grid>

                        <TextBlock Text="Saved passwords" FontWeight="Bold" Margin="0,10,0,6" />
                        <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Encrypted for this Windows account (the old app kept these in plain text)." />
                        <ListBox ItemsSource="{Binding Passwords}" SelectedItem="{Binding SelectedPassword}"
                                 Height="110">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding StatusText, StringFormat='   ({0})'}"
                                                   Style="{StaticResource SubtleText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Name (e.g. the sender):" Style="{StaticResource SubtleText}"
                                       FontSize="11" Margin="0,0,0,3" />
                            <TextBlock Grid.Column="1" Text="Password:" Style="{StaticResource SubtleText}"
                                       FontSize="11" Margin="0,0,0,3" />
                            <TextBox x:Name="NewPwLabel" Grid.Row="1" Margin="0,0,6,0"
                                     AutomationProperties.Name="New password label" />
                            <PasswordBox x:Name="NewPwValue" Grid.Row="1" Grid.Column="1" Margin="0,0,6,0"
                                         AutomationProperties.Name="New password" />
                            <Button Grid.Row="1" Grid.Column="2" Content="Add" Click="OnAddPassword"
                                    MinWidth="52" Margin="0,0,6,0" />
                            <Button Grid.Row="1" Grid.Column="3" Content="Remove"
                                    Command="{Binding RemovePasswordCommand}" />
                        </Grid>
                        <TextBlock x:Name="PwHint" Style="{StaticResource StatusText}" Margin="0,6,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
