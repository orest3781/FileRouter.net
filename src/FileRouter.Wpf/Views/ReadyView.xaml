<UserControl x:Class="FileRouter.Wpf.Views.ReadyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="{Binding CountLine}">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource HeadlineText}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CountAlertOn}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Danger}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Text="{Binding DetailLine}" Style="{StaticResource SubtleText}"
                   TextWrapping="Wrap" Margin="0,4,0,0" />

        <StackPanel Visibility="{Binding DashboardVisible, Converter={StaticResource BoolToVis}}"
                    Margin="0,16,0,0">
            <TextBlock Text="{Binding MonitorTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
            <ItemsControl ItemsSource="{Binding Tiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- a grid card per folder; a real Button, so it's
                             keyboard-focusable and screen-reader-named -->
                        <Button Command="{Binding OpenCommand}"
                                Background="{Binding Back, Converter={StaticResource RgbToBrush}}"
                                Foreground="{Binding Fore, Converter={StaticResource RgbToBrush}}"
                                AutomationProperties.Name="{Binding Display}"
                                ToolTip="{Binding Tooltip}"
                                MinHeight="78" Margin="0,0,6,6" Padding="12,8"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Top"
                                BorderThickness="0" Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding Fore, Converter={StaticResource RgbToBrush}}" />
                                <TextBlock Text="{Binding CountText}" FontSize="27" FontWeight="Bold"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Fore, Converter={StaticResource RgbToBrush}}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Button Content="Start Processing" Command="{Binding StartCommand}"
                Style="{StaticResource PrimaryButton}" Height="48" Margin="0,18,0,0"
                FontSize="15" />
        <Button Content="Rescan inbox" Command="{Binding RescanCommand}"
                Height="36" Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
