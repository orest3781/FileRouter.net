<UserControl x:Class="FileRouter.Wpf.Views.DoneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="{Binding CountLine}" Style="{StaticResource HeadlineText}"
                   Foreground="{DynamicResource Theme.Success}" />
        <TextBlock Text="{Binding DetailLine}" TextWrapping="Wrap" Margin="0,6,0,0" />

        <Button Content="Back to inbox" Command="{Binding RescanCommand}"
                Style="{StaticResource PrimaryButton}" Height="42" Margin="0,18,0,0" />
        <Button Content="Undo last   ·   Ctrl+Shift+Z" Command="{Binding UndoCommand}"
                Height="36" Margin="0,8,0,0" />

        <TextBlock Text="{Binding StatusLine}" Style="{StaticResource StatusText}"
                   Margin="0,12,0,0" />
    </StackPanel>
</UserControl>
