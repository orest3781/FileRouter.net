<Window x:Class="FileRouter.Wpf.Windows.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileRouter — History" Width="980" Height="640" MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource {x:Type Window}}">
    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Find in history" />
        </DockPanel>

        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button Content="Export to spreadsheet…" Command="{Binding ExportCommand}"
                    DockPanel.Dock="Right" />
            <Button Content="Show all" Command="{Binding ShowAllCommand}"
                    DockPanel.Dock="Right" Margin="0,0,8,0"
                    Visibility="{Binding CanShowAll, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding FooterText}" VerticalAlignment="Center"
                       Style="{StaticResource SubtleText}" />
        </DockPanel>

        <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column"
                  SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Reverted}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Theme.SubtleText}" />
                            <Setter Property="FontStyle" Value="Italic" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="When" Binding="{Binding When}" Width="140" />
                <DataGridTextColumn Header="Original" Binding="{Binding Original}" Width="*" />
                <DataGridTextColumn Header="Filed as" Binding="{Binding FiledAs}" Width="*" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" />
                <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="120" />
                <DataGridCheckBoxColumn Header="Undone" Binding="{Binding Reverted}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
