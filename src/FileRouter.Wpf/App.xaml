<Application x:Class="FileRouter.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FileRouter.Wpf.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <views:RgbToBrushConverter x:Key="RgbToBrush" />
            <views:InvertBoolConverter x:Key="InvertBool" />
            <views:ColorStringToBrushConverter x:Key="ColorStringToBrush" />
            <views:ColorStringToForeBrushConverter x:Key="ColorStringToForeBrush" />
            <views:SwatchCheckConverter x:Key="SwatchCheck" />
            <views:ZeroToVisibilityConverter x:Key="ZeroToVis" />
            <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
            <sys:Double x:Key="AppFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
